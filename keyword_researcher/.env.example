# Vertex AI (set for deployment; optional for local adk run)
GOOGLE_GENAI_USE_VERTEXAI=1
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# Model (used by root_agent)
GOOGLE_API_KEY="your-api-key-here"
MODEL=gemini-2.5-flash

# Deploy: staging bucket for Agent Engine
STAGING_BUCKET=gs://your-staging-bucket-here

# Deploy: set to update an existing Reasoning Engine instead of creating one
# REASONING_ENGINE_RESOURCE_NAME=projects/your-project-id/locations/us-central1/reasoningEngines/your-reasoning-engine-id
