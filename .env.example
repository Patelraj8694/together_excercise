# =============================================================================
# Project Root .env — single source of truth for all services
# Copy to .env and fill in your values.
# =============================================================================

# -----------------------------------------------------------------------------
# Budget Pacing Service
# All optional — sensible defaults are built in.
# -----------------------------------------------------------------------------
BP_DAILY_LIMIT=1000.0
BP_MAX_BID=10.0
BP_BASE_BID=1.0
BP_PACING_MIN_FACTOR=0.1
BP_PACING_MAX_FACTOR=2.0
# Default: SQLite file. For PostgreSQL: postgresql://user:pass@host:5432/dbname
BP_DATABASE_URI=sqlite:///budget_pacing.db

# -----------------------------------------------------------------------------
# Keyword Researcher — Local Development
# Only needed when running: adk web --port 8000
# -----------------------------------------------------------------------------
GOOGLE_API_KEY=your-gemini-api-key
MODEL=gemini-2.5-flash
ADK_LOCAL_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# Keyword Researcher — Google Cloud / Vertex AI (production)
# Uncomment and fill these after deploying with: python deploy.py
# -----------------------------------------------------------------------------
# GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_CLOUD_LOCATION=us-central1
# GOOGLE_GENAI_USE_VERTEXAI=1
# STAGING_BUCKET=gs://your-project-id-staging
# REASONING_ENGINE_RESOURCE_NAME=projects/your-project-id/locations/us-central1/reasoningEngines/your-engine-id
